*.__i
*.i
*.ii
*.su

# Logs considered generated by the cleaner
JLinkLog.txt
*.jlink
*.log

# Generated build directories
Objects/
Listings/
Debug/
Release/
__pycache__/
**/Objects/
**/Listings/
**/Debug/
**/Release/
**/__pycache__/

# Python/editor/system temporary files
*.pyc
*.pyo
*.swp
*.swo
*~
